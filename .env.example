# 数据库配置
# 默认 docker-compose.yml 会同时启动一个独立的 MySQL 容器，DB_HOST 保持 mysql 即可。
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
# 首次部署请运行 python generate_env.py 自动生成随机密码，或手动填写强密码。
DB_PASSWORD=
DB_NAME=iptv-all-in-one
DB_CHARSET=utf8mb4

# 默认 MySQL 容器只映射到宿主机本地 127.0.0.1，不对局域网或公网开放。
MYSQL_HOST_PORT=3306

# 默认 MySQL 容器轻量参数；8G 或更小服务器建议保持默认。
# 如果数据量较大或并发较高，可适当调大 MYSQL_INNODB_BUFFER_POOL_SIZE 和 MYSQL_MAX_CONNECTIONS。
MYSQL_PERFORMANCE_SCHEMA=OFF
MYSQL_INNODB_BUFFER_POOL_SIZE=64M
MYSQL_INNODB_LOG_BUFFER_SIZE=8M
MYSQL_MAX_CONNECTIONS=50
MYSQL_TABLE_OPEN_CACHE=200
MYSQL_TABLE_DEFINITION_CACHE=400

# 使用外部 MySQL 时，改成你的数据库连接信息，并使用 docker-compose.external-mysql.yml 启动。
# DB_HOST=你的数据库IP
# DB_PORT=3306
# DB_USER=你的用户名
# DB_PASSWORD=你的密码
# DB_NAME=iptv-all-in-one
# DB_CHARSET=utf8mb4

# Web 访问端口：宿主机端口，容器内固定为 58080
PORT=58080
